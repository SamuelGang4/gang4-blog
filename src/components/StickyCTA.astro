---
/**
 * StickyCTA — Barre sticky bottom avec CTA contextuel
 *
 * Reco audit seo-sxo (2026-05-09) :
 * - Le libellé doit refléter l'angle de l'article, pas un message produit générique
 * - Driver BOFU >1.5% (objectif révisé)
 * - Apparaît au scroll après 300px (évite l'irritation immédiate)
 */

interface Props {
  label: string;
  href: string;
  contextLabel?: string; // Ex: "Voir comment Gang4 gère votre whitelisting"
}

const { label, href, contextLabel } = Astro.props;
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 transform translate-y-full transition-transform duration-500 ease-out"
  data-sticky-cta
>
  <div class="bg-gang4-deep/95 backdrop-blur-xl border-t border-white/10 shadow-2xl">
    <div class="container-wide py-4 flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="text-sm text-white/80 text-center md:text-left">
        {contextLabel ? (
          <>
            <strong class="text-white">Envie d'aller plus loin ?</strong>
            <span class="ml-2 text-white/60">{contextLabel}</span>
          </>
        ) : (
          <strong class="text-white">Prêt à scaler votre whitelisting Meta ?</strong>
        )}
      </div>

      <div class="flex items-center gap-3">
        <a
          href={href}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-gang4-vivid hover:bg-gang4-glow text-white rounded-full text-sm font-semibold glow-button whitespace-nowrap"
        >
          {label}
          <span>→</span>
        </a>
        <button
          type="button"
          aria-label="Fermer"
          class="text-white/40 hover:text-white/80 transition-colors p-1"
          data-sticky-close
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Apparition au scroll (>300px) + bouton de fermeture (avec localStorage)
  const stickyCta = document.querySelector('[data-sticky-cta]') as HTMLElement;
  const closeBtn = document.querySelector('[data-sticky-close]') as HTMLElement;

  if (stickyCta) {
    const isClosed = localStorage.getItem('sticky-cta-closed') === 'true';

    if (!isClosed) {
      let visible = false;

      const handleScroll = () => {
        const shouldShow = window.scrollY > 300;
        if (shouldShow && !visible) {
          stickyCta.classList.remove('translate-y-full');
          visible = true;
        } else if (!shouldShow && visible) {
          stickyCta.classList.add('translate-y-full');
          visible = false;
        }
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();
    }

    closeBtn?.addEventListener('click', () => {
      stickyCta.classList.add('translate-y-full');
      localStorage.setItem('sticky-cta-closed', 'true');
    });
  }
</script>
