---
/**
 * DataTable — Tableau premium réutilisable dans MDX
 *
 * Usage simple :
 * <DataTable
 *   headers={["Dimension", "Avant", "Après"]}
 *   rows={[
 *     ["Architecture", "3 algos isolés", "1 modèle ML unifié"],
 *     ["Capacité", "×1", "**×10 000**"],
 *   ]}
 * />
 *
 * Usage avancé avec colonnes typées (mise en valeur dernière colonne) :
 * <DataTable
 *   headers={["Dimension", "Avant", "Après"]}
 *   rows={[...]}
 *   highlight="last"  // "first" | "last" | "none"
 *   caption="Comparaison Avant/Après Andromeda"
 * />
 */

interface Props {
  headers: string[];
  rows: (string | number)[][];
  highlight?: 'first' | 'last' | 'none';
  caption?: string;
  compact?: boolean;
}

const { headers, rows, highlight = 'last', caption, compact = false } = Astro.props;

// Mini parser markdown pour **bold** dans les cellules
function renderCell(content: string | number): string {
  const str = String(content);
  return str
    .replace(/\*\*(.+?)\*\*/g, '<strong class="text-white">$1</strong>')
    .replace(/`([^`]+)`/g, '<code class="px-1.5 py-0.5 rounded bg-white/10 text-gang4-vivid text-[0.85em] font-mono">$1</code>');
}

const colCount = headers.length;
---

<figure class="my-8 -mx-4 md:mx-0 overflow-x-auto">
  <div class="inline-block min-w-full align-middle">
    <div class="overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02]">
      <table class="min-w-full">
        <thead class="bg-gang4-vivid/[0.08] border-b border-white/10">
          <tr>
            {headers.map((header, i) => (
              <th
                scope="col"
                class:list={[
                  'px-4 md:px-5 py-3 text-left text-[11px] md:text-xs font-bold uppercase tracking-widest text-white/90',
                  highlight === 'last' && i === colCount - 1 && 'text-gang4-vivid',
                  highlight === 'first' && i === 0 && 'text-gang4-vivid',
                ]}
              >
                {header}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, rowIdx) => (
            <tr class:list={[
              'border-b border-white/[0.06] last:border-0',
              'hover:bg-white/[0.03] transition-colors',
            ]}>
              {row.map((cell, colIdx) => (
                <td
                  class:list={[
                    compact ? 'px-4 md:px-5 py-2.5' : 'px-4 md:px-5 py-3.5',
                    'text-sm md:text-[15px] leading-snug',
                    'align-top',
                    colIdx === 0 && 'font-semibold text-white',
                    colIdx !== 0 && 'text-white/75',
                    highlight === 'last' && colIdx === colCount - 1 && 'text-white bg-gang4-vivid/[0.04]',
                    highlight === 'first' && colIdx === 0 && 'text-white bg-gang4-vivid/[0.04]',
                  ]}
                  set:html={renderCell(cell)}
                />
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  {caption && (
    <figcaption class="text-center text-xs text-white/40 italic mt-3 px-4">
      {caption}
    </figcaption>
  )}
</figure>
