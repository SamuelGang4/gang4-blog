---
/**
 * Navbar — cohérence avec gang4-landing (à enrichir avec le vrai design Lovable plus tard)
 */
---

<header class="border-b border-white/10 bg-gang4-deep/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="container-wide flex items-center justify-between py-4">
    <a href="https://gang4.io" class="flex items-center gap-2 text-xl font-bold">
      <span>Gang4</span>
      <span class="text-xs text-white/50 font-normal">Blog</span>
    </a>

    <div class="flex items-center gap-6 text-sm">
      <a href="/blog" class="text-white/70 hover:text-white transition-colors">Articles</a>
      <a href="https://gang4.io/whitelisting" class="text-white/70 hover:text-white transition-colors">
        Whitelisting
      </a>
      <a
        href="https://gang4.io/whitelisting#demo"
        class="px-4 py-2 bg-white text-gang4-deep rounded-lg font-medium hover:bg-white/90 transition-colors"
      >
        Réserver une démo
      </a>
    </div>
  </nav>
</header>
