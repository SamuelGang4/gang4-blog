---
/**
 * Navbar — DA cohérent avec gang4-landing (Lovable)
 */
const currentPath = Astro.url.pathname;
---

<header class="border-b border-white/[0.08] bg-gang4-deep/80 backdrop-blur-xl sticky top-0 z-50">
  <nav class="container-wide flex items-center justify-between py-5">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/logo-gang4.svg"
        alt="Gang4"
        class="h-8 w-auto group-hover:opacity-90 transition-opacity"
        loading="eager"
      />
      <span class="text-[10px] text-white/50 font-semibold uppercase tracking-widest border-l border-white/15 pl-3">Blog</span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a
        href="/"
        class={`transition-colors ${currentPath === '/' ? 'text-white' : 'text-white/60 hover:text-white'}`}
      >
        Accueil
      </a>
      <a
        href="/blog"
        class={`transition-colors ${currentPath.startsWith('/blog') ? 'text-white' : 'text-white/60 hover:text-white'}`}
      >
        Articles
      </a>
      <a
        href="https://gang4.io/whitelisting"
        class="text-white/60 hover:text-white transition-colors"
      >
        Solution
      </a>
    </div>

    <a
      href="https://gang4.io/whitelisting#demo"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-gang4-vivid hover:bg-gang4-glow text-white rounded-full text-sm font-semibold glow-button"
    >
      Réserver une démo
      <span class="text-xs">→</span>
    </a>
  </nav>
</header>
