---
/**
 * ArticleMeta — Méta inline d'un article (reading time + auteur + date + pillar)
 *
 * Reco audit seo-sxo (2026-05-09) :
 * - Reading time = signal de respect du temps lecteur (CMO sur mobile)
 * - Auteur visible = E-E-A-T fort
 * - Date = signal de fraîcheur
 */

interface Props {
  authorName: string;
  authorTitle?: string;
  authorHref?: string;
  publishedAt: Date;
  updatedAt?: Date;
  readingTimeMinutes?: number;
  pillarLabel?: string;
}

const {
  authorName,
  authorTitle,
  authorHref,
  publishedAt,
  updatedAt,
  readingTimeMinutes,
  pillarLabel,
} = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<div class="flex flex-wrap items-center gap-3 text-sm text-white/60">
  {pillarLabel && (
    <>
      <span class="pill pill-vivid text-[10px]">{pillarLabel}</span>
      <span class="text-white/30">·</span>
    </>
  )}

  <span>
    Par{' '}
    {authorHref ? (
      <a href={authorHref} class="text-white/80 hover:text-white font-semibold transition-colors">
        {authorName}
      </a>
    ) : (
      <strong class="text-white/80">{authorName}</strong>
    )}
  </span>

  {authorTitle && (
    <>
      <span class="text-white/30">·</span>
      <span class="text-white/50">{authorTitle}</span>
    </>
  )}

  <span class="text-white/30">·</span>

  <time datetime={publishedAt.toISOString()}>
    Publié le {formatDate(publishedAt)}
  </time>

  {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
    <>
      <span class="text-white/30">·</span>
      <time datetime={updatedAt.toISOString()} class="italic">
        MAJ {formatDate(updatedAt)}
      </time>
    </>
  )}

  {readingTimeMinutes && (
    <>
      <span class="text-white/30">·</span>
      <span class="inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        {readingTimeMinutes} min de lecture
      </span>
    </>
  )}
</div>
