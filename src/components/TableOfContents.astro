---
/**
 * TableOfContents — TOC sticky desktop, repliable mobile
 *
 * Génère automatiquement la navigation depuis les <h2> du slot rendu.
 * Sur mobile : affiché en <details> repliable au-dessus du contenu.
 * Sur desktop : intégré au-dessus de la sidebar (hors scope ici, version inline).
 *
 * Note : Astro ne peut pas extraire les headings du slot dynamiquement côté serveur
 * sans plugin. On utilise une version JS-light qui parse le DOM côté client.
 */
---

<aside class="toc not-prose my-6 lg:hidden">
  <details class="rounded-xl border border-white/10 bg-white/[0.03] overflow-hidden group">
    <summary class="cursor-pointer list-none px-5 py-3 flex items-center justify-between gap-3 hover:bg-white/[0.05] transition-colors">
      <span class="flex items-center gap-2 text-sm font-semibold text-white/90">
        <svg class="w-4 h-4 text-gang4-vivid" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        Sommaire de l'article
      </span>
      <span class="text-gang4-vivid text-lg group-open:rotate-45 transition-transform">+</span>
    </summary>
    <nav class="px-5 pb-4 pt-1" data-toc-nav>
      <ol class="space-y-1.5 text-sm text-white/70 list-decimal list-inside marker:text-gang4-vivid marker:font-bold">
        <!-- injecté par script -->
      </ol>
    </nav>
  </details>
</aside>

<script>
  // Génère la TOC depuis les <h2> de l'article
  const article = document.querySelector('article .prose');
  const tocNav = document.querySelector('[data-toc-nav] ol');
  if (article && tocNav) {
    const h2s = article.querySelectorAll('h2');
    if (h2s.length === 0) {
      const tocAside = document.querySelector('.toc');
      tocAside?.remove();
    } else {
      h2s.forEach((h2, i) => {
        // S'assurer qu'on a un id (rehype-slug le fait normalement, fallback sinon)
        if (!h2.id) {
          h2.id = `section-${i + 1}-${(h2.textContent || '')
            .toLowerCase()
            .normalize('NFD')
            .replace(/[̀-ͯ]/g, '')
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-|-$/g, '')}`;
        }
        const li = document.createElement('li');
        li.className = 'pl-1';
        const a = document.createElement('a');
        a.href = `#${h2.id}`;
        a.textContent = h2.textContent || '';
        a.className = 'text-white/70 hover:text-gang4-vivid transition-colors underline-offset-2 hover:underline';
        li.appendChild(a);
        tocNav.appendChild(li);
      });
    }
  }
</script>
