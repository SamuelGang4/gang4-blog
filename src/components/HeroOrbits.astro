---
/**
 * HeroOrbits · Animation futuriste pour le hero du blog
 *
 * Concept : "Constellation Meta" — une métaphore visuelle d'Andromeda et de
 * l'écosystème ad tech IA. Noyau central pulsant + 3 anneaux orbitaux 3D +
 * nœuds lumineux + particules d'arrière-plan + lignes de connexion.
 *
 * Pure CSS animations (zéro JS, performance maximale).
 * Affiché uniquement md+ (caché sur mobile pour ne pas charger inutilement).
 */
---

<div class="hero-orbits hidden lg:flex relative items-center justify-center w-full h-[480px]" aria-hidden="true">
  <!-- Particules d'arrière-plan (floating sparks) -->
  <div class="absolute inset-0 overflow-hidden">
    {Array.from({ length: 18 }).map((_, i) => (
      <span
        class="spark"
        style={`--i:${i}; --x:${(i * 37) % 100}%; --d:${4 + (i % 5)}s; --delay:${(i * 0.4) % 6}s; --size:${1 + (i % 3)}px`}
      />
    ))}
  </div>

  <!-- Noyau central pulsant -->
  <div class="absolute z-30 core">
    <div class="core-inner"></div>
    <div class="core-halo"></div>
  </div>

  <!-- Anneau orbital 1 (rapide, proche) -->
  <div class="orbit orbit-1">
    <div class="orbit-ring"></div>
    <span class="node node-a"></span>
    <span class="node node-b"></span>
  </div>

  <!-- Anneau orbital 2 (medium, milieu) -->
  <div class="orbit orbit-2">
    <div class="orbit-ring"></div>
    <span class="node node-c"></span>
    <span class="node node-d"></span>
    <span class="node node-e"></span>
  </div>

  <!-- Anneau orbital 3 (lent, externe) -->
  <div class="orbit orbit-3">
    <div class="orbit-ring"></div>
    <span class="node node-f"></span>
    <span class="node node-g"></span>
  </div>

  <!-- SVG connection lines (subtle web between nodes via the core) -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-40" viewBox="0 0 480 480" fill="none">
    <defs>
      <radialGradient id="lineGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="hsl(231, 100%, 74%)" stop-opacity="0.8" />
        <stop offset="100%" stop-color="hsl(231, 100%, 74%)" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx="240" cy="240" r="180" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-3" />
    <circle cx="240" cy="240" r="130" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-2" />
    <circle cx="240" cy="240" r="80" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-1" />
  </svg>
</div>

<style>
  .hero-orbits {
    /* perspective for 3D feel */
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* === NOYAU CENTRAL === */
  .core {
    width: 36px;
    height: 36px;
    animation: core-pulse 3.6s ease-in-out infinite;
  }

  .core-inner {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, hsl(231, 100%, 84%) 0%, hsl(231, 100%, 74%) 60%, transparent 100%);
    box-shadow:
      0 0 20px hsl(231, 100%, 74% / 0.6),
      0 0 40px hsl(231, 100%, 74% / 0.4),
      0 0 80px hsl(231, 100%, 74% / 0.3);
  }

  .core-halo {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    background: radial-gradient(circle, hsl(231, 100%, 74% / 0.15) 0%, transparent 70%);
    animation: halo-breathe 4s ease-in-out infinite;
  }

  @keyframes core-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.15); }
  }

  @keyframes halo-breathe {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%      { transform: scale(1.5); opacity: 1; }
  }

  /* === ORBITES === */
  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    transform-style: preserve-3d;
  }

  .orbit-1 {
    width: 160px;
    height: 160px;
    margin-top: -80px;
    margin-left: -80px;
    transform: rotateX(72deg);
    animation: orbit-spin 14s linear infinite;
  }

  .orbit-2 {
    width: 260px;
    height: 260px;
    margin-top: -130px;
    margin-left: -130px;
    transform: rotateX(64deg) rotateZ(30deg);
    animation: orbit-spin 22s linear infinite reverse;
  }

  .orbit-3 {
    width: 360px;
    height: 360px;
    margin-top: -180px;
    margin-left: -180px;
    transform: rotateX(70deg) rotateZ(-15deg);
    animation: orbit-spin 32s linear infinite;
  }

  @keyframes orbit-spin {
    from { transform: rotateX(var(--rx, 70deg)) rotateZ(var(--rz, 0deg)) rotateY(0deg); }
    to   { transform: rotateX(var(--rx, 70deg)) rotateZ(var(--rz, 0deg)) rotateY(360deg); }
  }

  /* Override avec les transformations spécifiques par orbite */
  .orbit-1 { animation-name: orbit-1-spin; }
  .orbit-2 { animation-name: orbit-2-spin; }
  .orbit-3 { animation-name: orbit-3-spin; }

  @keyframes orbit-1-spin {
    from { transform: rotateX(72deg) rotateY(0deg); }
    to   { transform: rotateX(72deg) rotateY(360deg); }
  }
  @keyframes orbit-2-spin {
    from { transform: rotateX(64deg) rotateZ(30deg) rotateY(0deg); }
    to   { transform: rotateX(64deg) rotateZ(30deg) rotateY(-360deg); }
  }
  @keyframes orbit-3-spin {
    from { transform: rotateX(70deg) rotateZ(-15deg) rotateY(0deg); }
    to   { transform: rotateX(70deg) rotateZ(-15deg) rotateY(360deg); }
  }

  .orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid hsl(231, 100%, 74% / 0.25);
    box-shadow: inset 0 0 30px hsl(231, 100%, 74% / 0.1);
  }

  /* === NOEUDS LUMINEUX === */
  .node {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: hsl(231, 100%, 84%);
    box-shadow:
      0 0 8px hsl(231, 100%, 74% / 0.9),
      0 0 16px hsl(231, 100%, 74% / 0.6),
      0 0 24px hsl(231, 100%, 74% / 0.3);
    top: 50%;
    left: 50%;
    margin-top: -4px;
    margin-left: -4px;
  }

  /* Positionnement des nodes sur leurs orbites */
  .node-a { transform: translate(80px, 0); }
  .node-b { transform: translate(-80px, 0); }

  .node-c { transform: translate(130px, 0); }
  .node-d { transform: translate(-65px, 112px); }
  .node-e { transform: translate(-65px, -112px); }

  .node-f { transform: translate(180px, 0); }
  .node-g { transform: translate(-180px, 0); }

  /* Pulse subtil sur certains nodes pour donner de la vie */
  .node-a, .node-d, .node-f { animation: node-pulse 2.4s ease-in-out infinite; }
  .node-b, .node-e, .node-g { animation: node-pulse 2.4s ease-in-out infinite 1.2s; }
  .node-c { animation: node-pulse 3s ease-in-out infinite 0.6s; }

  @keyframes node-pulse {
    0%, 100% {
      opacity: 0.6;
      filter: brightness(0.9);
    }
    50%      {
      opacity: 1;
      filter: brightness(1.4);
    }
  }

  /* === ANNEAUX SVG (glow ambient) === */
  .ring-glow {
    transform-origin: center;
    animation: ring-rotate 40s linear infinite;
  }
  .ring-glow-1 { animation-duration: 25s; }
  .ring-glow-2 { animation-duration: 45s; animation-direction: reverse; }
  .ring-glow-3 { animation-duration: 60s; }

  @keyframes ring-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* === PARTICULES D'ARRIÈRE-PLAN === */
  .spark {
    position: absolute;
    bottom: -20px;
    left: var(--x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: hsl(231, 100%, 84%);
    box-shadow: 0 0 6px hsl(231, 100%, 74% / 0.8);
    opacity: 0;
    animation: spark-rise var(--d) linear var(--delay) infinite;
  }

  @keyframes spark-rise {
    0%   {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    10%  { opacity: 0.6; }
    50%  {
      opacity: 1;
      transform: translateY(-240px) translateX(8px);
    }
    90%  { opacity: 0.4; }
    100% {
      transform: translateY(-480px) translateX(-4px);
      opacity: 0;
    }
  }

  /* Respect des préférences utilisateur (reduced motion) */
  @media (prefers-reduced-motion: reduce) {
    .core,
    .core-halo,
    .orbit-1,
    .orbit-2,
    .orbit-3,
    .node-a, .node-b, .node-c, .node-d, .node-e, .node-f, .node-g,
    .ring-glow,
    .spark {
      animation: none;
    }
    .spark { opacity: 0.4; }
  }
</style>
