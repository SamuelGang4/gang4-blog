---
/**
 * HeroOrbits · Animation futuriste pour le hero du blog
 *
 * Concept : "Constellation Meta" — une métaphore visuelle d'Andromeda et de
 * l'écosystème ad tech IA. Noyau central pulsant + 3 anneaux orbitaux 3D +
 * nœuds lumineux + particules d'arrière-plan + lignes de connexion.
 *
 * Pure CSS animations (zéro JS, performance maximale).
 * Affiché uniquement md+ (caché sur mobile pour ne pas charger inutilement).
 */
---

<div class="hero-orbits hidden lg:flex relative items-center justify-center w-full h-[640px]" aria-hidden="true">
  <!-- Particules d'arrière-plan (floating sparks) -->
  <div class="absolute inset-0 overflow-hidden">
    {Array.from({ length: 40 }).map((_, i) => (
      <span
        class="spark"
        style={`--i:${i}; --x:${(i * 23) % 100}%; --d:${4 + (i % 6)}s; --delay:${(i * 0.3) % 7}s; --size:${1 + (i % 3)}px`}
      />
    ))}
  </div>

  <!-- Noyau central pulsant -->
  <div class="absolute z-30 core">
    <div class="core-inner"></div>
    <div class="core-halo"></div>
  </div>

  <!-- Anneau orbital 1 (rapide, proche) -->
  <div class="orbit orbit-1">
    <div class="orbit-ring"></div>
    <span class="node node-a"></span>
    <span class="node node-b"></span>
    <span class="node node-h"></span>
  </div>

  <!-- Anneau orbital 2 (medium, milieu) -->
  <div class="orbit orbit-2">
    <div class="orbit-ring"></div>
    <span class="node node-c"></span>
    <span class="node node-d"></span>
    <span class="node node-e"></span>
    <span class="node node-i"></span>
    <span class="node node-j"></span>
  </div>

  <!-- Anneau orbital 3 (medium-slow, large) -->
  <div class="orbit orbit-3">
    <div class="orbit-ring"></div>
    <span class="node node-f"></span>
    <span class="node node-g"></span>
    <span class="node node-k"></span>
    <span class="node node-l"></span>
  </div>

  <!-- Anneau orbital 4 (lent, le plus externe) -->
  <div class="orbit orbit-4">
    <div class="orbit-ring"></div>
    <span class="node node-m"></span>
    <span class="node node-n"></span>
    <span class="node node-o"></span>
  </div>

  <!-- SVG connection lines (subtle web between nodes via the core) -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none opacity-40" viewBox="0 0 640 640" fill="none">
    <defs>
      <radialGradient id="lineGrad" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="hsl(231, 100%, 74%)" stop-opacity="0.8" />
        <stop offset="100%" stop-color="hsl(231, 100%, 74%)" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx="320" cy="320" r="280" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-4" />
    <circle cx="320" cy="320" r="220" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-3" />
    <circle cx="320" cy="320" r="155" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-2" />
    <circle cx="320" cy="320" r="95" stroke="url(#lineGrad)" stroke-width="0.5" fill="none" class="ring-glow ring-glow-1" />
  </svg>
</div>

<style>
  .hero-orbits {
    /* perspective for 3D feel */
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* === NOYAU CENTRAL === */
  .core {
    width: 52px;
    height: 52px;
    animation: core-pulse 3.6s ease-in-out infinite;
  }

  .core-inner {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, hsl(231, 100%, 84%) 0%, hsl(231, 100%, 74%) 60%, transparent 100%);
    box-shadow:
      0 0 28px hsl(231, 100%, 74% / 0.7),
      0 0 60px hsl(231, 100%, 74% / 0.5),
      0 0 120px hsl(231, 100%, 74% / 0.35);
  }

  .core-halo {
    position: absolute;
    inset: -24px;
    border-radius: 50%;
    background: radial-gradient(circle, hsl(231, 100%, 74% / 0.18) 0%, transparent 70%);
    animation: halo-breathe 4s ease-in-out infinite;
  }

  @keyframes core-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.15); }
  }

  @keyframes halo-breathe {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50%      { transform: scale(1.5); opacity: 1; }
  }

  /* === ORBITES === */
  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    transform-style: preserve-3d;
  }

  .orbit-1 {
    width: 190px;
    height: 190px;
    margin-top: -95px;
    margin-left: -95px;
    animation: orbit-1-spin 14s linear infinite;
  }

  .orbit-2 {
    width: 310px;
    height: 310px;
    margin-top: -155px;
    margin-left: -155px;
    animation: orbit-2-spin 22s linear infinite;
  }

  .orbit-3 {
    width: 440px;
    height: 440px;
    margin-top: -220px;
    margin-left: -220px;
    animation: orbit-3-spin 32s linear infinite;
  }

  .orbit-4 {
    width: 560px;
    height: 560px;
    margin-top: -280px;
    margin-left: -280px;
    animation: orbit-4-spin 48s linear infinite;
  }

  @keyframes orbit-1-spin {
    from { transform: rotateX(72deg) rotateY(0deg); }
    to   { transform: rotateX(72deg) rotateY(360deg); }
  }
  @keyframes orbit-2-spin {
    from { transform: rotateX(64deg) rotateZ(30deg) rotateY(0deg); }
    to   { transform: rotateX(64deg) rotateZ(30deg) rotateY(-360deg); }
  }
  @keyframes orbit-3-spin {
    from { transform: rotateX(70deg) rotateZ(-15deg) rotateY(0deg); }
    to   { transform: rotateX(70deg) rotateZ(-15deg) rotateY(360deg); }
  }
  @keyframes orbit-4-spin {
    from { transform: rotateX(68deg) rotateZ(45deg) rotateY(0deg); }
    to   { transform: rotateX(68deg) rotateZ(45deg) rotateY(-360deg); }
  }

  .orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid hsl(231, 100%, 74% / 0.25);
    box-shadow: inset 0 0 30px hsl(231, 100%, 74% / 0.1);
  }

  /* === NOEUDS LUMINEUX === */
  .node {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: hsl(231, 100%, 84%);
    box-shadow:
      0 0 10px hsl(231, 100%, 74% / 0.95),
      0 0 22px hsl(231, 100%, 74% / 0.65),
      0 0 36px hsl(231, 100%, 74% / 0.35);
    top: 50%;
    left: 50%;
    margin-top: -5px;
    margin-left: -5px;
  }

  /* Variation de taille pour certains nodes (donne du rythme visuel) */
  .node-a, .node-c, .node-g, .node-k, .node-n {
    width: 7px;
    height: 7px;
    margin-top: -3.5px;
    margin-left: -3.5px;
  }

  /* Orbite 1 (rayon 95px) — 3 nodes répartis à 120° */
  .node-a { transform: translate(95px, 0); }
  .node-b { transform: translate(-47.5px, 82.3px); }
  .node-h { transform: translate(-47.5px, -82.3px); }

  /* Orbite 2 (rayon 155px) — 5 nodes répartis à 72° */
  .node-c { transform: translate(155px, 0); }
  .node-d { transform: translate(47.9px, 147.4px); }
  .node-e { transform: translate(-125.4px, 91.1px); }
  .node-i { transform: translate(-125.4px, -91.1px); }
  .node-j { transform: translate(47.9px, -147.4px); }

  /* Orbite 3 (rayon 220px) — 4 nodes répartis à 90° */
  .node-f { transform: translate(220px, 0); }
  .node-g { transform: translate(0, 220px); }
  .node-k { transform: translate(-220px, 0); }
  .node-l { transform: translate(0, -220px); }

  /* Orbite 4 (rayon 280px) — 3 nodes répartis à 120° */
  .node-m { transform: translate(280px, 0); }
  .node-n { transform: translate(-140px, 242.5px); }
  .node-o { transform: translate(-140px, -242.5px); }

  /* Pulse subtil sur les nodes (alternance pour donner de la vie) */
  .node-a, .node-d, .node-f, .node-i, .node-l, .node-m {
    animation: node-pulse 2.4s ease-in-out infinite;
  }
  .node-b, .node-e, .node-g, .node-h, .node-j, .node-n {
    animation: node-pulse 2.4s ease-in-out infinite 1.2s;
  }
  .node-c, .node-k, .node-o {
    animation: node-pulse 3s ease-in-out infinite 0.6s;
  }

  @keyframes node-pulse {
    0%, 100% {
      opacity: 0.6;
      filter: brightness(0.9);
    }
    50%      {
      opacity: 1;
      filter: brightness(1.4);
    }
  }

  /* === ANNEAUX SVG (glow ambient) === */
  .ring-glow {
    transform-origin: center;
    animation: ring-rotate 40s linear infinite;
  }
  .ring-glow-1 { animation-duration: 25s; }
  .ring-glow-2 { animation-duration: 45s; animation-direction: reverse; }
  .ring-glow-3 { animation-duration: 60s; }
  .ring-glow-4 { animation-duration: 80s; animation-direction: reverse; }

  @keyframes ring-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* === PARTICULES D'ARRIÈRE-PLAN === */
  .spark {
    position: absolute;
    bottom: -20px;
    left: var(--x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: hsl(231, 100%, 84%);
    box-shadow: 0 0 6px hsl(231, 100%, 74% / 0.8);
    opacity: 0;
    animation: spark-rise var(--d) linear var(--delay) infinite;
  }

  @keyframes spark-rise {
    0%   {
      transform: translateY(0) translateX(0);
      opacity: 0;
    }
    10%  { opacity: 0.7; }
    50%  {
      opacity: 1;
      transform: translateY(-320px) translateX(10px);
    }
    90%  { opacity: 0.4; }
    100% {
      transform: translateY(-660px) translateX(-6px);
      opacity: 0;
    }
  }

  /* Respect des préférences utilisateur (reduced motion) */
  @media (prefers-reduced-motion: reduce) {
    .core,
    .core-halo,
    .orbit-1, .orbit-2, .orbit-3, .orbit-4,
    .node-a, .node-b, .node-c, .node-d, .node-e, .node-f, .node-g,
    .node-h, .node-i, .node-j, .node-k, .node-l, .node-m, .node-n, .node-o,
    .ring-glow,
    .spark {
      animation: none;
    }
    .spark { opacity: 0.4; }
  }
</style>
