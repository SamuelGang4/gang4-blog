---
/**
 * SidebarLeadMagnet — Lead magnet sticky en sidebar (style Ben & Vic)
 *
 * Affiche le lead magnet contextuel de l'article + bio auteur compacte +
 * CTA démo. Apparaît dans la sidebar droite sur desktop, en pleine largeur
 * sur mobile.
 */

interface Props {
  leadMagnet?: {
    type: string;
    title: string;
    description?: string;
    bullets: string[];
    ctaLabel: string;
    url: string;
    image?: string;
    eyebrow?: string;
  };
  ctaLabel?: string;
  ctaHref?: string;
}

const { leadMagnet, ctaLabel, ctaHref } = Astro.props;

const typeIcons: Record<string, string> = {
  'pdf-gated': '📄',
  'tool': '🛠️',
  'newsletter': '📬',
  'template': '📋',
  'database': '📊',
  'audit': '🔍',
  'webinar': '🎥',
};
---

<aside class="sidebar-sticky">
  <div class="space-y-5">

    <!-- 🎁 Lead magnet principal (si défini) -->
    {leadMagnet && (
      <div class="card-glass p-5 border-gang4-vivid/30 bg-gradient-to-br from-gang4-vivid/10 to-gang4-glow/5">
        {leadMagnet.eyebrow && (
          <div class="text-[10px] font-bold uppercase tracking-widest text-gang4-vivid mb-2">
            ⚡ {leadMagnet.eyebrow}
          </div>
        )}

        {leadMagnet.image && (
          <img
            src={leadMagnet.image}
            alt={leadMagnet.title}
            class="w-full rounded-lg mb-4 border border-white/10"
            loading="lazy"
          />
        )}

        <h3 class="font-bold text-base leading-tight mb-4">{leadMagnet.title}</h3>

        <form
          action={leadMagnet.url}
          method="POST"
          name="lead-magnet-sidebar"
          data-netlify="true"
          class="space-y-2"
        >
          <input type="hidden" name="form-name" value="lead-magnet-sidebar" />
          <input type="hidden" name="lead_magnet" value={leadMagnet.title} />

          <input
            type="email"
            name="email"
            required
            placeholder="ton@email.pro"
            class="w-full px-4 py-2.5 rounded-full bg-white/[0.08] border border-white/15 text-white placeholder:text-white/40 focus:outline-none focus:border-gang4-vivid focus:bg-white/[0.12] transition-all text-sm"
          />

          <button
            type="submit"
            class="block w-full text-center px-4 py-3 bg-gang4-vivid hover:bg-gang4-glow text-white rounded-full text-sm font-bold glow-button transition-all"
          >
            {leadMagnet.ctaLabel}
          </button>
        </form>

        <p class="text-[10px] text-white/40 text-center mt-2">
          🔒 100% gratuit · Pas de spam
        </p>
      </div>
    )}

  </div>
</aside>

<style>
  .sidebar-sticky {
    position: sticky;
    top: 100px; /* Compense le header sticky */
    align-self: start;
  }
</style>
