---
/**
 * SidebarLeadMagnet — Lead magnet sticky en sidebar (style Ben & Vic)
 *
 * Affiche le lead magnet contextuel de l'article + bio auteur compacte +
 * CTA démo. Apparaît dans la sidebar droite sur desktop, en pleine largeur
 * sur mobile.
 */

interface Props {
  leadMagnet?: {
    type: string;
    title: string;
    description?: string;
    bullets: string[];
    ctaLabel: string;
    url: string;
    image?: string;
    eyebrow?: string;
  };
  ctaLabel?: string;
  ctaHref?: string;
}

const { leadMagnet, ctaLabel, ctaHref } = Astro.props;

const typeIcons: Record<string, string> = {
  'pdf-gated': '📄',
  'tool': '🛠️',
  'newsletter': '📬',
  'template': '📋',
  'database': '📊',
  'audit': '🔍',
  'webinar': '🎥',
};
---

<aside class="sidebar-sticky">
  <div class="space-y-5">

    <!-- 🎁 Lead magnet principal (si défini) -->
    {leadMagnet && (
      <div class="card-glass p-5 border-gang4-vivid/30 bg-gradient-to-br from-gang4-vivid/10 to-gang4-glow/5">
        {leadMagnet.eyebrow && (
          <div class="text-[10px] font-bold uppercase tracking-widest text-gang4-vivid mb-2">
            ⚡ {leadMagnet.eyebrow}
          </div>
        )}

        {leadMagnet.image ? (
          <img
            src={leadMagnet.image}
            alt={leadMagnet.title}
            class="w-full rounded-lg mb-4 border border-white/10"
            loading="lazy"
          />
        ) : (
          <!-- Mockup placeholder si pas d'image -->
          <div class="aspect-[4/5] rounded-lg mb-4 border border-white/10 bg-gradient-to-br from-gang4-vivid/30 via-gang4-glow/20 to-gang4-deep relative overflow-hidden">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center">
              <div class="text-4xl mb-2">{typeIcons[leadMagnet.type] || '📄'}</div>
              <div class="text-xs font-semibold text-white/70 uppercase tracking-wider">{leadMagnet.type}</div>
              <div class="text-sm font-bold text-white mt-2 leading-tight">{leadMagnet.title}</div>
            </div>
            <div class="absolute bottom-2 right-2 pill pill-muted text-[8px]">Preview</div>
          </div>
        )}

        <h3 class="font-bold text-base leading-tight mb-2">{leadMagnet.title}</h3>

        {leadMagnet.description && (
          <p class="text-sm text-white/65 leading-relaxed mb-3">{leadMagnet.description}</p>
        )}

        {leadMagnet.bullets.length > 0 && (
          <ul class="space-y-1.5 mb-4">
            {leadMagnet.bullets.map((b) => (
              <li class="flex items-start gap-2 text-xs text-white/70">
                <span class="text-gang4-vivid mt-0.5">✓</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        )}

        <a
          href={leadMagnet.url}
          class="block w-full text-center px-4 py-3 bg-gang4-vivid hover:bg-gang4-glow text-white rounded-full text-sm font-bold glow-button transition-all"
        >
          {leadMagnet.ctaLabel}
        </a>

        <p class="text-[10px] text-white/40 text-center mt-2">
          🔒 100% gratuit · Pas de spam
        </p>
      </div>
    )}

    <!-- 🎯 Mini CTA démo -->
    {ctaLabel && ctaHref && (
      <div class="card-glass p-4 text-center">
        <div class="text-2xl mb-2">🚀</div>
        <h3 class="font-bold text-sm mb-2 leading-tight">
          Prêt à scaler votre whitelisting Meta ?
        </h3>
        <a
          href={ctaHref}
          class="inline-block w-full text-center px-3 py-2 bg-white/[0.08] hover:bg-white/[0.15] border border-white/15 text-white rounded-full text-xs font-semibold transition-all"
        >
          {ctaLabel} →
        </a>
      </div>
    )}

  </div>
</aside>

<style>
  .sidebar-sticky {
    position: sticky;
    top: 100px; /* Compense le header sticky */
    align-self: start;
  }
</style>
