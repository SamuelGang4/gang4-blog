---
/**
 * SidebarLeadMagnet · Lead magnet sticky en sidebar (style Ben & Vic)
 *
 * Capture email côté client via fetch() vers un webhook n8n.
 * Le webhook n8n se charge d'envoyer l'email de confirmation
 * (3 noeuds : Webhook → validation → Gmail Send) avec les credentials
 * Gmail OAuth déjà configurés dans n8n.
 *
 * UX : 3 états (idle / loading / success / error) gérés en JS pur.
 *
 * Configuration : variable d'env Astro PUBLIC_N8N_LEAD_MAGNET_WEBHOOK
 * (préfixe PUBLIC_ pour exposition côté client, sans secret sensible).
 */

interface Props {
  leadMagnet?: {
    type: string;
    title: string;
    description?: string;
    bullets: string[];
    ctaLabel: string;
    url: string;
    image?: string;
    eyebrow?: string;
  };
  ctaLabel?: string;
  ctaHref?: string;
}

const { leadMagnet, ctaLabel, ctaHref } = Astro.props;

// URL du webhook n8n configurée via env (cf. .env / Netlify env vars).
// Fallback sur une chaîne vide : le formulaire affichera une erreur claire si la var n'est pas définie.
const webhookUrl = import.meta.env.PUBLIC_N8N_LEAD_MAGNET_WEBHOOK || '';
---

<aside class="sidebar-sticky">
  <div class="space-y-5">

    <!-- 🎁 Lead magnet principal (si défini) -->
    {leadMagnet && (
      <div class="card-glass p-5 border-gang4-vivid/30 bg-gradient-to-br from-gang4-vivid/10 to-gang4-glow/5">
        {leadMagnet.eyebrow && (
          <div class="text-[10px] font-bold uppercase tracking-widest text-gang4-vivid mb-2">
            ⚡ {leadMagnet.eyebrow}
          </div>
        )}

        {leadMagnet.image && (
          <img
            src={leadMagnet.image}
            alt={leadMagnet.title}
            class="w-full rounded-lg mb-4 border border-white/10"
            loading="lazy"
          />
        )}

        <h3 class="font-bold text-base leading-tight mb-4">{leadMagnet.title}</h3>

        <form
          class="lead-magnet-form space-y-2"
          data-lead-magnet={leadMagnet.title}
          data-webhook={webhookUrl}
          data-fallback-url={leadMagnet.url}
        >
          <input
            type="email"
            name="email"
            required
            placeholder="ton@email.pro"
            autocomplete="email"
            class="lm-email w-full px-4 py-2.5 rounded-full bg-white/[0.08] border border-white/15 text-white placeholder:text-white/40 focus:outline-none focus:border-gang4-vivid focus:bg-white/[0.12] transition-all text-sm"
          />

          <!-- Honeypot anti-bot : champ caché, si rempli on bloque côté client -->
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            class="lm-honeypot"
            aria-hidden="true"
          />

          <button
            type="submit"
            class="lm-submit block w-full text-center px-4 py-3 bg-gang4-vivid hover:bg-gang4-glow text-white rounded-full text-sm font-bold glow-button transition-all"
          >
            <span class="lm-label">{leadMagnet.ctaLabel}</span>
            <span class="lm-loading hidden">Envoi en cours…</span>
          </button>

          <p class="lm-success hidden text-center text-sm text-gang4-glow mt-3 leading-snug">
            ✓ C'est noté. Tu reçois un email de confirmation tout de suite,<br />
            et tes 20 créas dans les 72h.
          </p>

          <p class="lm-error hidden text-center text-xs text-red-300 mt-2"></p>
        </form>

        <p class="lm-disclaimer text-[10px] text-white/40 text-center mt-2">
          🔒 100% gratuit · Pas de spam
        </p>
      </div>
    )}

  </div>
</aside>

<style>
  .sidebar-sticky {
    position: sticky;
    top: 100px; /* Compense le header sticky */
    align-self: start;
  }
  /* Honeypot vraiment invisible (sans display:none, sinon les bots intelligents skip) */
  .lm-honeypot {
    position: absolute;
    left: -9999px;
    top: -9999px;
    height: 0;
    width: 0;
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  // Capture côté client + POST async vers webhook n8n
  document.querySelectorAll<HTMLFormElement>('.lead-magnet-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = form.querySelector<HTMLInputElement>('.lm-email');
      const honeypotInput = form.querySelector<HTMLInputElement>('.lm-honeypot');
      const submitBtn = form.querySelector<HTMLButtonElement>('.lm-submit');
      const labelEl = form.querySelector<HTMLElement>('.lm-label');
      const loadingEl = form.querySelector<HTMLElement>('.lm-loading');
      const successEl = form.querySelector<HTMLElement>('.lm-success');
      const errorEl = form.querySelector<HTMLElement>('.lm-error');

      if (!emailInput || !submitBtn) return;

      // Honeypot : si rempli, c'est un bot. On simule success sans rien envoyer.
      if (honeypotInput && honeypotInput.value.trim() !== '') {
        emailInput.classList.add('hidden');
        submitBtn.classList.add('hidden');
        successEl?.classList.remove('hidden');
        return;
      }

      const email = emailInput.value.trim();
      const leadMagnet = form.getAttribute('data-lead-magnet') || '20 créas UGC';
      const webhookUrl = form.getAttribute('data-webhook') || '';
      const fallbackUrl = form.getAttribute('data-fallback-url') || '';

      if (!webhookUrl) {
        if (errorEl) {
          errorEl.textContent = 'Configuration manquante. Écris-nous à samuel@gang4.io';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      // UX : passer en loading
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-75', 'cursor-wait');
      labelEl?.classList.add('hidden');
      loadingEl?.classList.remove('hidden');
      errorEl?.classList.add('hidden');

      try {
        const res = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            lead_magnet: leadMagnet,
            source_url: window.location.href,
            submitted_at: new Date().toISOString(),
          }),
        });

        if (!res.ok) {
          throw new Error(`Erreur ${res.status}`);
        }

        // SUCCESS : cacher le form, afficher le message
        emailInput.classList.add('hidden');
        submitBtn.classList.add('hidden');
        successEl?.classList.remove('hidden');

        // Cacher la disclaimer "100% gratuit" qui devient redondante
        const disclaimer = form.parentElement?.querySelector<HTMLElement>('.lm-disclaimer');
        disclaimer?.classList.add('hidden');
      } catch (err: any) {
        // ERROR : restaurer le form et afficher le message
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-75', 'cursor-wait');
        labelEl?.classList.remove('hidden');
        loadingEl?.classList.add('hidden');

        if (errorEl) {
          errorEl.textContent = 'Erreur lors de l\'envoi. Réessaie ou écris à samuel@gang4.io';
          errorEl.classList.remove('hidden');
        }

        // Fallback : si 2e échec, on redirige vers la page démo
        if (fallbackUrl && form.dataset.failCount === '1') {
          window.location.href = fallbackUrl;
        }
        form.dataset.failCount = '1';
      }
    });
  });
</script>
